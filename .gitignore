# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.venv/
*.egg-info/

# Node / pnpm
node_modules/
pnpm-debug.log
.pnpm-store/

# Vite per-contributor env overrides (e.g. VITE_WPC_API_URL pointing
# at a dev community host). Never commit — leaks dev URLs into the
# tree and makes `pnpm build` produce divergent bundles per checkout.
.env.local
.env.*.local

# Build outputs
js/
web/
coverage/
.coverage
.vitest-cache/

# Scratch dir for screenshots, lighthouse reports, and other artifacts
# generated during local QA. Never belongs in the tree.
.tmp/

# Archives never belong in the repo (caught a stray src.zip
# hand-dropped into the tree on Apr 26)
*.zip
*.tar
*.tar.gz
*.tgz

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude / Superpowers workspace artifacts
.superpowers/
.claude/
# Backups dropped by /caveman:compress next to compressed files
*.original.md

# Docs — ignore everything except per-node help pages + canonical contracts
/docs/*
!/docs/help/
!/docs/import-export-contract.md
# Curated release highlights — read by .releaserc.js at release time, so it
# must be tracked (the release step commits the cleared file back).
!/docs/release-notes/

# Semantic release
.releaserc.local.js

# Throwaway design / scratch artifacts (mockups, screenshots, demos)
/_temp/

# DB location control — per-contributor sidecar config + root-location DB dir
db-config.json
/db/
