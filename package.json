{
  "name": "comfyui-wildcard-pipeline",
  "version": "1.4.1",
  "private": true,
  "description": "Modular procedural prompt generation for ComfyUI",
  "author": "DumiFlex",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "vite build --watch --mode extension",
    "build:extension": "vite build --mode extension && pnpm docs:copy",
    "build:manager": "vite build --mode manager",
    "build": "pnpm build:extension && pnpm build:manager",
    "docs:copy": "node scripts/copy-help-docs.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "size": "node scripts/check-bundle-size.mjs",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:py": "pytest",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.5.12",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.6",
    "primeicons": "^7.0.0"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20",
    "@comfyorg/comfyui-frontend-types": "^1.42.15",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.31.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "husky": "^9.1.6",
    "jsdom": "^29.0.2",
    "semantic-release": "^25.0.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vitest": "^2.1.4",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10"
  }
}
